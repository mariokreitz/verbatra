{
  "name": "@verbatra/format-adapters",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Format adapters for verbatra: file formats to and from core's intermediate representation",
  "license": "MIT",
  "author": "Mario Kreitz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/verbatra.git",
    "directory": "packages/format-adapters"
  },
  "homepage": "https://github.com/mariokreitz/verbatra/tree/main/packages/format-adapters",
  "bugs": {
    "url": "https://github.com/mariokreitz/verbatra/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "catalog:bundled",
    "@verbatra/core": "workspace:*",
    "@xmldom/xmldom": "catalog:bundled",
    "yaml": "catalog:bundled"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@verbatra/config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

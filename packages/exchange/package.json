{
  "name": "@verbatra/exchange",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Translator interchange for verbatra: build and read styled Excel workbooks over a neutral, format-agnostic row model.",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "excel",
    "xlsx",
    "interchange",
    "verbatra"
  ],
  "license": "MIT",
  "author": "Mario Kreitz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/verbatra.git",
    "directory": "packages/exchange"
  },
  "homepage": "https://github.com/mariokreitz/verbatra/tree/main/packages/exchange",
  "bugs": {
    "url": "https://github.com/mariokreitz/verbatra/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "exceljs": "catalog:bundled",
    "jszip": "catalog:bundled",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@verbatra/config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

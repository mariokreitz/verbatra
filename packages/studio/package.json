{
  "name": "@verbatra/studio",
  "version": "0.1.0-next.4",
  "type": "module",
  "description": "Local Verbatra Studio dashboard: a read-only web view over a verbatra project, served from a prebuilt single-page app.",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "dashboard",
    "studio",
    "verbatra"
  ],
  "license": "MIT",
  "author": "Mario Kreitz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/verbatra.git",
    "directory": "packages/studio"
  },
  "homepage": "https://github.com/mariokreitz/verbatra/tree/main/packages/studio",
  "bugs": {
    "url": "https://github.com/mariokreitz/verbatra/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup && vite build",
    "dev:app": "vite build --watch --minify false",
    "dev:server": "tsx watch src/dev/server.ts",
    "lint": "biome check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@verbatra/sdk": "workspace:*",
    "chokidar": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@verbatra/config": "workspace:*",
    "@verbatra/format-adapters": "workspace:*",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "tsx": "4.23.0",
    "typescript": "catalog:",
    "vite": "8.0.16",
    "vitest": "catalog:"
  }
}

{
  "name": "@verbatra/sdk",
  "version": "0.4.1",
  "type": "module",
  "description": "Programmatic API to automate i18n translation and keep your locale files in sync across languages with AI and machine-translation providers.",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "translate",
    "locale",
    "ai",
    "machine-translation",
    "deepl",
    "openai",
    "anthropic",
    "gemini",
    "i18next",
    "vue-i18n",
    "next-intl",
    "ngx-translate",
    "sdk",
    "automation"
  ],
  "license": "MIT",
  "author": "Mario Kreitz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/verbatra.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://verbatra.kreitz-webdev.de",
  "bugs": {
    "url": "https://github.com/mariokreitz/verbatra/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.107.0",
    "@formatjs/icu-messageformat-parser": "3.5.12",
    "@google/genai": "2.10.0",
    "@xmldom/xmldom": "0.9.10",
    "chokidar": "5.0.0",
    "cosmiconfig": "9.0.2",
    "cosmiconfig-typescript-loader": "6.3.0",
    "deepl-node": "1.27.0",
    "exceljs": "4.4.0",
    "jszip": "3.10.1",
    "loglevel": "1.9.2",
    "openai": "6.45.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@verbatra/ai-providers": "workspace:*",
    "@verbatra/config": "workspace:*",
    "@verbatra/core": "workspace:*",
    "@verbatra/exchange": "workspace:*",
    "@verbatra/format-adapters": "workspace:*",
    "@vitest/coverage-v8": "4.1.9",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}

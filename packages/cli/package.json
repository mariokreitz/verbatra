{
  "name": "@verbatra/cli",
  "version": "0.4.1",
  "type": "module",
  "description": "Command-line tool to automate i18n translation and keep your locale files in sync across languages with AI and machine-translation providers.",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "translate",
    "locale",
    "ai",
    "machine-translation",
    "deepl",
    "openai",
    "anthropic",
    "gemini",
    "i18next",
    "vue-i18n",
    "next-intl",
    "ngx-translate",
    "cli",
    "automation"
  ],
  "license": "MIT",
  "author": "Mario Kreitz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/verbatra.git",
    "directory": "packages/cli"
  },
  "homepage": "https://verbatra.kreitz-webdev.de",
  "bugs": {
    "url": "https://github.com/mariokreitz/verbatra/issues"
  },
  "bin": {
    "verbatra": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@verbatra/sdk": "workspace:*",
    "commander": "15.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@verbatra/config": "workspace:*",
    "@vitest/coverage-v8": "4.1.9",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}

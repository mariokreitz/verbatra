# Copy this file to .env and set your Gemini API key. Do not commit your real key.
#
# verbatra loads .env (and .env.local) from this directory automatically and reads
# the provider key from the environment only - never from verbatra.config.ts.
# Get a free key at https://aistudio.google.com/apikey, then run: pnpm i18n
GEMINI_API_KEY=

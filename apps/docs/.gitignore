# Secrets — never commit. verbatra loads .env automatically and reads the
# provider key (GEMINI_API_KEY) from the environment only. The root .gitignore
# already ignores these; this local copy makes the boundary explicit and mirrors
# what `verbatra init` scaffolds for any consuming project.
.env
.env.local

# ...but the template (key name only, no real value) is meant to be committed.
!.env.example

# Disable pnpm's implicit "verify deps before run" check. When the lockfile
# drifts it aborts every `pnpm <cmd>` (including git hooks) with a cryptic
# ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY / modules-purge prompt. Lockfile
# integrity is instead enforced explicitly: the `lockfile` pre-commit hook runs
# `pnpm install --frozen-lockfile --lockfile-only`, and CI installs are frozen
# by default.
verify-deps-before-run=false

{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["PUBLISHED_PACKAGES_JSON"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "@verbatra/github-action#build": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
